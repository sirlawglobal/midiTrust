# ==========================================
# MediTrust Backend Environment Configuration (Example)
# ==========================================

# --------------------------
# APPLICATION SERVER
# --------------------------
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# --------------------------
# DATABASE (MongoDB via Mongoose)
# --------------------------
DATABASE_URI=mongodb://127.0.0.1:27017/meditrust_db
DATABASE_MAX_POOL_SIZE=100
DATABASE_MIN_POOL_SIZE=10

# --------------------------
# REDIS (Caching & BullMQ)
# --------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=meditrust:

# --------------------------
# AUTHENTICATION (JWT & Admin Setup)
# --------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

SUPER_ADMIN_EMAIL=admin@meditrust-hospital.com
SUPER_ADMIN_PASSWORD=SuperSecretAdmin2026!

# --------------------------
# MONNIFY (Payments & Virtual Accounts)
# --------------------------
MONNIFY_API_KEY=MK_TEST_XXXXXXXXXX
MONNIFY_SECRET_KEY=SK_TEST_XXXXXXXXXX
MONNIFY_CONTRACT_CODE=XXXXXXXXXX
MONNIFY_BASE_URL=https://sandbox.monnify.com/api/v1

# --------------------------
# CLOUDFLARE R2 (Receipts & PDF Storage)
# --------------------------
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=meditrust-receipts
CLOUDFLARE_R2_PUBLIC_URL=https://receipts.meditrust-hospital.com

# --------------------------
# MESSAGING (SMS & WhatsApp & Email)
# --------------------------
SMS_PROVIDER=termii
TERMII_API_KEY=TLXXXXXXXXXXXXX
TERMII_SENDER_ID=MediTrust

WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAXXXXXXXXXXXXX

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=mailtrap_user
SMTP_PASSWORD=mailtrap_pass
SMTP_FROM=billing@meditrust-hospital.com
