# ==========================================
# MediTrust Backend Environment Configuration (Example)
# ==========================================

# --------------------------
# APPLICATION SERVER
# --------------------------
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,https://your-production-domain.com

# --------------------------
# DATABASE (MongoDB via Mongoose)
# --------------------------
DATABASE_URI=mongodb://127.0.0.1:27017/meditrust_db
DATABASE_MAX_POOL_SIZE=100
DATABASE_MIN_POOL_SIZE=10

# --------------------------
# REDIS (Caching & BullMQ)
# --------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=meditrust:

# --------------------------
# AUTHENTICATION (JWT & Admin Setup)
# --------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

ADMIN_EMAIL=admin@meditrust-hospital.com
ADMIN_PASSWORD=SuperSecretAdmin2026!

# --------------------------
# MONNIFY (Payments & Virtual Accounts)
# --------------------------
MONNIFY_API_KEY=MK_TEST_J0B7HAM704
